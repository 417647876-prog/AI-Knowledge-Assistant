APP_NAME=AI 企业知识库助手
APP_ENV=development
DATABASE_URL=postgresql+psycopg://knowledge:knowledge@localhost:5432/knowledge
JWT_SECRET_KEY=development-only-change-me-please-32-chars
JWT_ALGORITHM=HS256
JWT_ISSUER=ai-knowledge-assistant
JWT_AUDIENCE=ai-knowledge-assistant-web
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_SECURE=false
TRUSTED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
EMBEDDING_DIMENSIONS=512
CHUNK_SIZE=800
CHUNK_OVERLAP=120
EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=32
CHAT_PROVIDER=fake
CHAT_BASE_URL=https://api.deepseek.com
CHAT_API_KEY=
CHAT_MODEL=deepseek-v4-flash
CHAT_TIMEOUT_SECONDS=30
RAG_TOP_K_DEFAULT=5
RAG_TOP_K_MAX=20
RAG_SCORE_THRESHOLD=0.55
RAG_QUESTION_MAX_LENGTH=2000
